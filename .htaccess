Options -Indexes

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Block direct access to sensitive backend directories
RewriteRule ^(app|config|storage|vendor)(/.*)? - [F,NC,L]

# sites/s{id}/current/* — proxied through PHP (Apache can't serve files outside web root)
RewriteRule ^sites/s[0-9]+/current(/.*)?$ /site-serve.php [QSA,L,NC]

# Block direct access to any other sites/ paths
RewriteRule ^sites(/.*)?$ - [F,L]

# /docs → docs.html
RewriteRule ^docs/?$ /docs.html [L]
