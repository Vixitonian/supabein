Options -Indexes

RewriteEngine On

# Block direct access to sensitive backend directories
RewriteRule ^(app|config|storage|vendor)(/.*)? - [F,NC,L]

# sites/ is served directly by Apache (has its own hardening .htaccess)
# No rewrite — paths like /sites/p5/current/index.html resolve straight from disk
RewriteRule ^sites(/.*)?$ - [L]

# Route everything else through public_html/
# This lets you point the server document root at the repo root
# instead of the public_html/ subdirectory.
RewriteRule ^(.*)$ public_html/$1 [L,QSA]
