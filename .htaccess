Options -Indexes

RewriteEngine On

# Block direct access to sensitive backend directories
RewriteRule ^(app|config|storage|vendor)(/.*)? - [F,NC,L]

# sites/ is the hosting plane — served directly by Apache (has its own hardening .htaccess)
RewriteRule ^sites(/.*)?$ - [L]

# Redirect the bare root to the dashboard SPA
RewriteRule ^$ /dashboard/ [R=302,L]

# Internally rewrite everything else through public_html/
# The condition prevents re-rewriting on Apache's second pass (avoids public_html/public_html/... loop).
RewriteCond %{REQUEST_URI} !^/public_html/ [NC]
RewriteRule ^(.*)$ public_html/$1 [L,QSA]
