## Using the anon key in frontend JS

```js
const SUPABEIN = 'https://your-supabein-domain.com/api/v1';
const ANON_KEY = 'eyJ...'; // from project API tab — safe to embed in frontend

async function query(table, params = {}) {
  const qs = new URLSearchParams(params).toString();
  const res = await fetch(`${SUPABEIN}/data/PROJECT_ID/${table}?${qs}`, {
    headers: { Authorization: `Bearer ${ANON_KEY}` }
  });
  if (!res.ok) throw new Error(await res.text());
  return res.json();
}

async function insert(table, data) {
  const res = await fetch(`${SUPABEIN}/data/PROJECT_ID/${table}`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${ANON_KEY}` },
    body: JSON.stringify(data)
  });
  if (!res.ok) throw new Error(await res.text());
  return res.json();
}
```

